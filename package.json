{
  "name": "robot",
  "version": "1.0.0",
  "main": "dist/main/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on http://localhost:5173 dist/main/index.js && electronmon dist/main/index.js\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "start": "electron dist/main/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:screenshot": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts",
    "test:screenshot:coordinate": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:coordinate\"",
    "test:screenshot:agility": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:agility\"",
    "test:screenshot:tile-location": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:tile-location\"",
    "test:screenshot:cyan": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:cyan\"",
    "test:screenshot:attack": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:attack\"",
    "test:screenshot:motherlode-mine-box": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-mine-box\"",
    "test:screenshot:motherlode-deposit": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-deposit\"",
    "test:screenshot:motherlode-banking-green": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-banking-green\"",
    "test:screenshot:motherlode-banking-yellow": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-banking-yellow\"",
    "test:screenshot:motherlode-bag-full": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-bag-full\"",
    "test:screenshot:motherlode-bag-stats": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-bag-stats\"",
    "test:screenshot:motherlode-obstacle-red": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-obstacle-red\"",
    "test:screenshot:motherlode-collision": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-collision\"",
    "test:screenshot:motherlode-near-deposit": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-near-deposit\"",
    "test:screenshot:motherlode-targeting": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-targeting\"",
    "test:screenshot:motherlode-active-node": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:motherlode-active-node\"",
    "test:screenshot:player": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:player\"",
    "test:screenshot:bank-deposit-orb": "vitest run src/main/automate-bots/shared/screenshot-suites.vitest.ts -t \"test:screenshot:bank-deposit-orb\""
  },
  "electronmon": {
    "patterns": [
      "!ocr-debug/**",
      "!automate-bot-logs/**",
      "!saved-clicks/**"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electronmon": "^2.0.4",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "vitest": "^3.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "effect": "^3.21.1",
    "node-screenshots": "^0.2.8",
    "node-window-manager": "^2.2.4",
    "pngjs": "^7.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "robotjs": "^0.7.0",
    "uiohook-napi": "^1.5.5"
  }
}