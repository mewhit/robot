{
  "name": "robot",
  "version": "1.0.0",
  "main": "dist/main/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on http://localhost:5173 dist/main/index.js && electronmon dist/main/index.js\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "start": "electron dist/main/index.js",
    "test:screenshot:coordinate": "ts-node src/main/automate-bots/shared/coordinate-box-detector.spec.ts test-images/coordinate-box/*r-*.png",
    "test:screenshot:agility": "ts-node src/main/automate-bots/shared/agility-box-detector.spec.ts test-images/agility-box/*.png",
    "test:screenshot:tile-location": "ts-node src/main/automate-bots/shared/tile-location-detection.spec.ts test-images/tile-location-box/*.png",
    "test:screenshot:cyan": "ts-node src/main/automate-bots/shared/cyan-box-detector.spec.ts test-images/npc-box/*.png",
    "test:screenshot:attack": "ts-node src/main/automate-bots/shared/attack-box-detector.spec.ts test-images/attack-box/*.png",
    "test:screenshot:motherlode-mine": "ts-node src/main/automate-bots/shared/motherlode-mine-box-detector.spec.ts test-images/motherlode-mine-box/*.png",
    "test:screenshot:motherlode-deposit": "ts-node src/main/automate-bots/shared/motherlode-deposit-box-detector.spec.ts test-images/motherlode-mine-upstair-deposit/*.png",
    "test:screenshot:motherlode-banking-green": "ts-node src/main/automate-bots/shared/motherlode-banking-green-detector.spec.ts test-images/motherlode-banking-green/*.png",
    "test:screenshot:motherlode-banking-yellow": "ts-node src/main/automate-bots/shared/motherlode-banking-yellow-detector.spec.ts test-images/motherlode-banking-yellow/*.png",
    "test:screenshot:motherlode-bag-full": "ts-node src/main/automate-bots/shared/motherlode-bag-full-box-detector.spec.ts test-images/motherlode-bag-full-box/*.png",
    "test:screenshot:motherlode-bag-stats": "ts-node src/main/automate-bots/shared/motherlode-bag-stats-detector.spec.ts test-images/motherlode-bag-full-box/*.png",
    "test:screenshot:motherlode-obstacle-red": "ts-node src/main/automate-bots/shared/motherlode-obstacle-red-detector.spec.ts test-images/motherload-obstacle/*.png",
    "test:screenshot:motherlode-collision": "ts-node src/main/automate-bots/shared/player-obstacle-collision.spec.ts test-images/colide/*.png",
    "test:screenshot:motherlode-near-deposit": "ts-node src/main/automate-bots/shared/motherlode-near-deposit-transition.spec.ts test-images/motherlode-near-deposit-transition/*.png",
    "test:screenshot:motherlode-targeting": "ts-node src/main/automate-bots/shared/motherlode-target-selection.spec.ts image-test/motherlode-nearest-anchor.png",
    "test:screenshot:motherlode-active-node": "ts-node src/main/automate-bots/shared/motherlode-active-node.spec.ts test-images/motherlode-active-node/*.png",
    "test:screenshot:player": "ts-node src/main/automate-bots/shared/player-box-detector.spec.ts test-images/player/*.png",
    "test:screenshot:bank-deposit-orb": "ts-node src/main/automate-bots/shared/bank-deposit-orb-detector.spec.ts"
  },
  "electronmon": {
    "patterns": [
      "!ocr-debug/**",
      "!automate-bot-logs/**",
      "!saved-clicks/**"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electronmon": "^2.0.4",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "effect": "^3.21.1",
    "node-screenshots": "^0.2.8",
    "node-window-manager": "^2.2.4",
    "pngjs": "^7.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "robotjs": "^0.7.0",
    "uiohook-napi": "^1.5.5"
  }
}
